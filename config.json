  },

  "features": {
    "email_notifications": true,
    "user_authentication": true,
    "api_v2": false
  },

  "api_keys": {
    "stripe": "sk_test_XXXXXXXXXXXXXXXXXXXX",  
    "google_maps": "YOUR_GOOGLE_MAPS_API_KEY" 
  },


  "application": {
    "name": "My Awesome Application",
    "version": "1.0.0",
    "default_language": "en"
  }
}
