{
  "database": {
    "host": "localhost",
    "port": 5432,
    "user": "mydatabaseuser",
    "password": "mydatabasepassword",
    "name": "mydatabase"
  },

  "server": {
    "host": "0.0.0.0",
    "port": 8080,
    "max_connections": 100,
    "timeout_seconds": 30
  },

